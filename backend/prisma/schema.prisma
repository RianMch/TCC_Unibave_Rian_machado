// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENTE
  ADMIN
  TECNICO
}

enum Material {
  POLIETILENO
  POLIAMIDA
}

enum StatusOS {
  PENDENTE
  AGENDADA
  EM_EXECUCAO
  CONCLUIDA
}

enum Turno {
  MANHA
  TARDE
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String    @unique
  senha     String
  role      Role      @default(CLIENTE)
  pedidos   Pedido[]
  criadoEm  DateTime  @default(now())
}

model Pedido {
  id           Int          @id @default(autoincrement())
  largura      Float
  altura       Float
  area         Float
  material     Material
  precoTotal   Float
  status       StatusOS     @default(PENDENTE)
  turno        Turno?
  dataAgendada DateTime?
  usuarioId    Int
  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  tecnico      Tecnico?
  certificado  Certificado?
  criadoEm     DateTime     @default(now())

  // Um mesmo dia+turno só pode estar ocupado por um pedido por vez.
  // Pedidos sem agendamento (dataAgendada/turno nulos) não são afetados:
  // o Postgres trata cada par de NULLs como distinto entre si.
  @@unique([dataAgendada, turno])
}

model Tecnico {
  id       Int     @id @default(autoincrement())
  nome     String
  crea     String  @unique
  pedidoId Int?    @unique
  pedido   Pedido? @relation(fields: [pedidoId], references: [id])
}

model Certificado {
  id        Int      @id @default(autoincrement())
  codigo    String   @unique
  pedidoId  Int      @unique
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])
  emitidoEm DateTime @default(now())
  validoAte DateTime
}